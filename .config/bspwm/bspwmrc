run() {
  if ! pidof -q "$1"; then
    "$@" &
  fi
}

# Set system vars for polybar
"$HOME"/.config/bspwm/bin/SetSysVars

# Super tap ‚Üí F13 (grabbed by sxhkd as @F13 for the app launcher)
# xmodmap must run BEFORE sxhkd so keycode 93 = F13 is in the keymap
# when sxhkd initialises and grabs keycodes.
xmodmap -e "keycode 93 = F13" 2>/dev/null || true

# Launch sxhkd daemon (after xmodmap so it grabs keycode 93 / F13)
run sxhkd -c "${HOME}"/.config/bspwm/config/sxhkdrc

# xcape synthesises F13 on bare Super_L tap
pkill -x xcape 2>/dev/null; xcape -e 'Super_L=F13'

# Restore config files from session save, fallback to original backup
SESSION_DIR="$HOME/.config/bspwm/config/.session"
BACKUP_DIR="$HOME/.local/share/gh0stzk/config/bspwm/config"
CONFIG_DIR="$HOME/.config/bspwm/config"
for f in picom.conf picom-animations.conf xsettingsd jgmenurc; do
    if [ ! -s "$CONFIG_DIR/$f" ]; then
        if [ -s "$SESSION_DIR/$f" ]; then
            cp "$SESSION_DIR/$f" "$CONFIG_DIR/$f"
        elif [ -f "$BACKUP_DIR/$f" ]; then
            cp "$BACKUP_DIR/$f" "$CONFIG_DIR/$f"
        fi
    fi
done

# Restore micro editor settings from session
MICRO_DIR="$HOME/.config/micro"
MICRO_SESSION="$SESSION_DIR/micro"
if [ -d "$MICRO_SESSION" ]; then
    mkdir -p "$MICRO_DIR/colorschemes"
    [ -s "$MICRO_SESSION/settings.json" ] && cp "$MICRO_SESSION/settings.json" "$MICRO_DIR/settings.json"
    [ -s "$MICRO_SESSION/bindings.json" ] && cp "$MICRO_SESSION/bindings.json" "$MICRO_DIR/bindings.json"
    for cs in "$MICRO_SESSION/colorschemes/"*.micro; do
        [ -f "$cs" ] && cp "$cs" "$MICRO_DIR/colorschemes/"
    done
fi
# dunstrc: always restore from backup (module truncates global section each run)
cp "$BACKUP_DIR/dunstrc" "$CONFIG_DIR/dunstrc"

# Launch dunst
mkdir -p /run/user/$(id -u)/dunst /run/user/$(id -u)/clipcat /run/user/$(id -u)/ft_lock
pkill -x dunst 2>/dev/null; dunst -config "${HOME}"/.config/bspwm/config/dunstrc &

# Generate cheatsheet font scale before eww starts so fresh CSS is baked in
_cs_h=$(xrandr --current | awk '/\*/{match($0,/[0-9]+x([0-9]+)/,a); if(a[2]+0>m) m=a[2]+0} END{print m}')
_cs_h=${_cs_h:-1080}
if   [ "$_cs_h" -ge 2160 ]; then _cs_key="1.5rem"; _cs_alt="1.1rem"; _cs_cat="1rem";   _cs_title="3rem";  _cs_col="450px"
elif [ "$_cs_h" -ge 1440 ]; then _cs_key="1.2rem"; _cs_alt="0.95rem"; _cs_cat="0.9rem"; _cs_title="2.5rem"; _cs_col="380px"
else                              _cs_key="1rem";   _cs_alt="0.8rem"; _cs_cat="0.8rem"; _cs_title="2rem";  _cs_col="300px"
fi
cat > "${HOME}/.config/bspwm/eww/cheatsheet/_cs_scale.scss" << EOF
// Generated by bspwmrc based on screen resolution ‚ÄĒ do not edit manually
.title { font-size: ${_cs_title}; }
.keys { font-size: ${_cs_key}; }
.keys-alt { font-size: ${_cs_alt}; }
.category-bspwm, .category-system, .category-nodes, .category-move,
.category-apps, .category-workspaces, .category-power,
.category-preselection, .category-others { font-size: ${_cs_cat}; }
.column { min-width: ${_cs_col}; }
EOF

# Restart eww daemon BEFORE ThemeLaunch so Bar.bash and widgets start with fresh CSS
pkill -x eww 2>/dev/null; sleep 0.3
eww -c "${HOME}"/.config/bspwm/eww daemon &
sleep 0.5  # give eww time to initialize before ThemeLaunch opens widgets

# Kill picom before ThemeLaunch so 01-picom.sh writes config with no race
pkill -x picom 2>/dev/null; sleep 0.2

# Load current theme (Bar, picom config, wallpaper, bspwm rules, dunst, etc.)
"${HOME}"/.config/bspwm/bin/ThemeLaunch

# Launch mpd
pgrep -x mpd >/dev/null || mpd "${HOME}"/.config/mpd/mpd.conf

# Kill gsd-power to prevent auto-brightness via iio-sensor-proxy
pkill -x gsd-power 2>/dev/null

# Launch picom with GLX backend ‚ÄĒ now available via the GL host shim
# (GL_SHIM + LIBGL_DRIVERS_PATH set above redirects to Ubuntu mesa 23.2.1
# which supports DRM 3.42; the GLX shader renders proper rounded border colors)
pkill -x picom 2>/dev/null
picom --config "${HOME}"/.config/bspwm/config/picom.conf &

# Animated wallpaper is restored by ThemeLaunch ‚Üí 06-wallpaper.sh (ENGINE=Animated)

# Launch ft_lock daemon
# ft_lock daemon is started outside bwrap by bspwm.sh (overlay prevents exec here)

# Launch xsettingsd
run xsettingsd --config="${HOME}"/.config/bspwm/config/xsettingsd >/dev/null 2>&1

# Launch clipboard daemon
run clipcatd

# Launch polkit
run lxpolkit

# Start one time message
[ ! -f "$HOME/.config/bspwm/config/.first_run_done" ] && alacritty --hold -e sh -c 'cat "$HOME/.config/bspwm/config/FirstMessage.txt"; sleep 0.1' && touch "$HOME/.config/bspwm/config/.first_run_done"

# Start dbus if not running
if ! pgrep -x dbus-daemon >/dev/null; then
    eval "$(dbus-launch --sh-syntax --exit-with-session)"
fi

# BT favorite reconnect daemon
pkill -f bt-reconnect 2>/dev/null
"${HOME}"/.config/bspwm/bin/bt-reconnect &

# Apply timezone (junest has no systemd; enforce on every startup)
sudo ln -sf /usr/share/zoneinfo/Europe/Paris /etc/localtime
echo "Europe/Paris" | sudo tee /etc/timezone > /dev/null 2>&1
