#
#  bspwmrc ‚ÄĒ window manager startup configuration
#  Repo: https://github.com/SaruM4N3/42_bspwm_dotfile
# =============================================================

# Ensure Arch's readline takes priority over Ubuntu's in the overlay.
# Ubuntu's libreadline.so.8.1 (missing rl_trim_arg_from_keyseq) would otherwise
# shadow Arch's 8.3, causing random "undefined symbol" crashes in bash/zsh.
# /etc/ld.so.conf.d/00-arch-lib.conf pins /usr/lib first; ldconfig rebuilds
# the cache so that priority survives pacman post-install scripts overwriting it.
LD_LIBRARY_PATH=/usr/lib ldconfig 2>/dev/null || true

# Set environment variables
export PATH="$HOME/.config/bspwm/bin:$HOME/.cache/bspwm/gnome-wrappers:$PATH"

export LIBVA_DRIVERS_PATH=/usr/lib/x86_64-linux-gnu/dri

# Use Ubuntu's mesa GL/EGL libraries so all apps get hardware-accelerated OpenGL.
# junest's Arch mesa (even 24.3.4) can't negotiate GLX visuals with Ubuntu's Xorg
# server. Ubuntu's mesa 23.2.1 supports DRM 3.42 (kernel 5.15) natively.
# GL_SHIM contains only GL/EGL symlinks ‚ÄĒ not libstdc++/glibc ‚ÄĒ so Arch binaries
# keep their own C++ runtime while getting the compatible GL stack.
export GL_SHIM="$HOME/.config/bspwm/gl-host"
export LD_LIBRARY_PATH="$GL_SHIM${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
export LIBGL_DRIVERS_PATH=/usr/lib/x86_64-linux-gnu/dri

export XDG_CURRENT_DESKTOP='bspwm'
## Fix java applications
export _JAVA_AWT_WM_NONREPARENTING=1

