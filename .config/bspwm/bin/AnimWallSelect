#!/bin/sh
# Animated wallpaper selector with rofi thumbnail preview (mirrors WallSelect)

ASSETS="$HOME/Pictures/AnimatedWallpaper"
CACHE_DIR="$HOME/.cache/$USER/animwalls"
STATE_FILE="$HOME/.config/bspwm/config/.animwall_index"
LAST_FILE="$HOME/.config/bspwm/config/.animwall_last"

mkdir -p "$CACHE_DIR"

rofi_command="rofi -dmenu -theme $HOME/.config/bspwm/config/rofi-themes/WallSelect.rasi"

TMPLIST=$(mktemp)
find "$ASSETS" -type f \( -name "*.mp4" -o -name "*.mkv" -o -name "*.gif" \) | \
    sort > "$TMPLIST"

# Generate thumbnails in parallel — only for missing/stale entries
# 300px matches the rofi element-icon size (25% of 1080p = 270px)
while IFS= read -r video; do
    name=$(basename "$video")
    thumb="$CACHE_DIR/${name}.jpg"
    if [ ! -f "$thumb" ] || [ "$video" -nt "$thumb" ]; then
        ffmpeg -y -i "$video" -vframes 1 -vf "scale=300:300:force_original_aspect_ratio=increase,crop=300:300" \
            "$thumb" >/dev/null 2>&1 &
    fi
done < "$TMPLIST"
wait

# Build rofi list with thumbnails
selection=$(while IFS= read -r video; do
    name=$(basename "$video")
    thumb="$CACHE_DIR/${name}.jpg"
    [ -f "$thumb" ] && printf '%s\000icon\037%s\n' "$name" "$thumb"
done < "$TMPLIST" | $rofi_command)

[ -z "$selection" ] && { rm -f "$TMPLIST"; exit 0; }

video_path="$ASSETS/$selection"

# Save state for CycleAnimWall compatibility (index in sorted list)
idx=$(grep -n "/$selection$" "$TMPLIST" | cut -d: -f1)
[ -n "$idx" ] && echo "$idx" > "$STATE_FILE"
echo "$video_path" > "$LAST_FILE"
rm -f "$TMPLIST"

# Persist to theme-config.bash so ENGINE=Animated always restores the right wall
RICE=$(cat "$HOME/.config/bspwm/.rice" 2>/dev/null)
CFG="$HOME/.config/bspwm/rices/${RICE}/theme-config.bash"
[ -f "$CFG" ] && sed -i "s|^ANIMATED_WALL=.*|ANIMATED_WALL=\"$video_path\"|" "$CFG"

AnimatedWall --stop
AnimatedWall --start "$video_path"