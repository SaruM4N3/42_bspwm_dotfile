#!/bin/sh
# Animated wallpaper selector with rofi thumbnail preview (mirrors WallSelect)

ASSETS="$HOME/Pictures/AnimatedWallpaper"
CACHE_DIR="$HOME/.cache/$USER/animwalls"
STATE_FILE="$HOME/.config/bspwm/config/.animwall_index"
LAST_FILE="$HOME/.config/bspwm/config/.animwall_last"

mkdir -p "$CACHE_DIR"

rofi_command="rofi -dmenu -theme $HOME/.config/bspwm/config/rofi-themes/WallSelect.rasi"

# Generate thumbnail for each video if not cached or video is newer
for video in "$ASSETS"/*.mp4 "$ASSETS"/*.mkv "$ASSETS"/*.gif; do
    [ -f "$video" ] || continue
    name=$(basename "$video")
    thumb="$CACHE_DIR/${name}.jpg"
    if [ ! -f "$thumb" ] || [ "$video" -nt "$thumb" ]; then
        ffmpeg -y -i "$video" -vframes 1 -vf "scale=500:500:force_original_aspect_ratio=increase,crop=500:500" \
            "$thumb" >/dev/null 2>&1
    fi
done

# Build rofi list with thumbnails
selection=$(for video in "$ASSETS"/*.mp4 "$ASSETS"/*.mkv "$ASSETS"/*.gif; do
    [ -f "$video" ] || continue
    name=$(basename "$video")
    thumb="$CACHE_DIR/${name}.jpg"
    [ -f "$thumb" ] && printf '%s\000icon\037%s\n' "$name" "$thumb"
done | LC_ALL=C sort | $rofi_command)

[ -z "$selection" ] && exit 0

# Save state index for CycleAnimWall compatibility
index=$(echo "$selection" | grep -o '[0-9]*' | head -1)
[ -n "$index" ] && echo "$index" > "$STATE_FILE"
echo "$ASSETS/$selection" > "$LAST_FILE"

AnimatedWall --stop
AnimatedWall --start "$ASSETS/$selection"