#!/bin/sh
# =============================================================
#  discord — launcher for bspwm/junest environment
#
#  mesa is pinned to 24.3.4 (IgnorePkg in junest pacman.conf).
#  Mesa 25.x+ requires DRM 3.54 (kernel 6.6+); host is 5.15 (DRM 3.42).
#  With mesa 24.3.4, the amdgpu DRI driver initialises correctly,
#  so no --disable-gpu workaround is needed.
# =============================================================

exec /usr/bin/discord "$@"