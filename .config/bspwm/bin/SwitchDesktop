#!/bin/sh
# SwitchDesktop — directional workspace switch with slide animation.
# Pre-positions incoming tiled windows off-screen so picom's geometry
# animation slides them in from the correct direction.
# Usage: SwitchDesktop {prev|next|^N}

DIRECTION="$1"
[ -z "$DIRECTION" ] && exit 1

SCREEN_W=$(xrandr --current 2>/dev/null | awk '
    /primary/ && match($0,/[0-9]+x[0-9]+/) {
        split(substr($0,RSTART,RLENGTH),a,"x"); print a[1]; exit }
    / connected / && !w && match($0,/[0-9]+x[0-9]+/) {
        split(substr($0,RSTART,RLENGTH),a,"x"); w=a[1] }
    END { if (w) print w }')
[ -z "$SCREEN_W" ] && SCREEN_W=1920

# Resolve direction to an offset
case "$DIRECTION" in
    prev)  DX="-$SCREEN_W" ;;   # coming from the left
    next)  DX="$SCREEN_W"  ;;   # coming from the right
    *)
        # Numbered desktop (^N): compare indices to pick direction
        CURR_IDX=$(bspc query -D -d focused | xargs -I{} bspc query -D | grep -n {} | cut -d: -f1)
        TARGET_IDX=$(bspc query -D -d "$DIRECTION" 2>/dev/null | xargs -I{} bspc query -D | grep -n {} | cut -d: -f1)
        if [ -z "$TARGET_IDX" ]; then
            bspc desktop -f "$DIRECTION"; exit 0
        fi
        if [ "$TARGET_IDX" -gt "$CURR_IDX" ]; then
            DX="$SCREEN_W"
        else
            DX="-$SCREEN_W"
        fi
        ;;
esac

TARGET_D=$(bspc query -D -d "$DIRECTION" 2>/dev/null)
[ -z "$TARGET_D" ] && exit 0
[ "$TARGET_D" = "$(bspc query -D -d focused)" ] && exit 0

# Pre-position incoming tiled windows off-screen (they are currently hidden)
for win in $(bspc query -N -d "$TARGET_D" -n .window.tiled 2>/dev/null); do
    bspc node "$win" -v "$DX" 0
done

# Switch desktop
bspc desktop -f "$DIRECTION"

# Move windows back to real position — picom geometry animation slides them in
NEG_DX=$(( 0 - DX ))
for win in $(bspc query -N -d focused -n .window.tiled 2>/dev/null); do
    bspc node "$win" -v "$NEG_DX" 0
done
