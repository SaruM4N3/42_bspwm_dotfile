#!/bin/sh
# =============================================================
# Script to control prefered apps to launch for all themes
# Author:  z0mbi3
# Repo:    https://github.com/gh0stzk/dotfiles
# Date:    24.04.2025
# Copyright (C) 2021-2025 gh0stzk <z0mbi3.zk@protonmail.com>
# Licensed under GPL-3.0 license
# =============================================================

WIDGET_DIR="$HOME/.config/bspwm/eww"

case "$1" in
	--menu)
		RofiLauncher --launcher
		;;
	--rice)
		RiceSelector
		;;
	--terminal)
		Term --terminal
		;;
	--floating)
		Term --floating
		;;
	--update)
		Term --update
		;;
	--checkupdates)
		Term --checkupdates
		;;
	--netmanager)
		NetManagerDM
		;;
	--pass)
		RofiPass
		;;
	--bluetooth)
		rofi-bluetooth
		;;
	--clipboard)
		clipcat-menu
		;;
	--screenshot)
		ScreenShoTer
		;;
	--powermenu)
		PowerMenu
		;;
	--android)
		AndroidMount
		;;
	--keyboard)
		KeyBoardL
		;;
	--yazi)
		Term --yazi
		;;
	--nvim)
		Term --nvim
		;;
	--music)
		Term --music
		;;
	--fetch)
		Term --fetch
		;;
	--scratch)
		Bspwm-ScratchPad
		;;
		# Apps
	--filemanager)
		thunar --new-window
		;;
	--browser)
		brave
		;;
	--micro)
		Term --micro
		;;
	--editor)
		code
		;;
	--telegram)
		telegram-desktop
		;;
	--whats)
		firefox -new-tab https://web.whatsapp.com/
		;;
	--soundcontrol)
		pavucontrol
		;;
	--KeyHelp)
		eval "$(xrandr --current | awk '/\*/{match($0,/([0-9]+)x([0-9]+)/,a); if(a[2]+0>mh){mw=a[1]+0; mh=a[2]+0}} END{
			if(mh>=2160)      {wp=0.82; hp=0.78}
			else if(mh>=1440) {wp=0.80; hp=0.72}
			else              {wp=0.76; hp=0.66}
			printf "cs_w=%d cs_h=%d\n", mw*wp, mh*hp
		}')"
		eww -c "$WIDGET_DIR" update cheatsheet_data="$(gen-cheatsheet-data)"
		eww -c "$WIDGET_DIR" open --toggle csheet --size "${cs_w}x${cs_h}"
		;;
	--usercard)
		if eww -c "$WIDGET_DIR" active-windows 2>/dev/null | grep -q "launchermenu"; then
			eww -c "$WIDGET_DIR" close launchermenu
		else
			eww -c "$WIDGET_DIR" open launchermenu
		fi
		;;
	--player)
		eww -c "$WIDGET_DIR" open --toggle music
		;;
	*)
		echo "Invalid Option"
		;;
esac
